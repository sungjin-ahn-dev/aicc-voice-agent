# ===========================================================
# AICC 서버 환경변수 — 이 파일을 .env 로 복사해서 값을 채우세요
#   cp .env.example .env
# ===========================================================

# ── CLAW OPS (전화 telephony) ── [필수]
CLAWOPS_API_KEY=
CLAWOPS_ACCOUNT_ID=
CLAWOPS_WEBHOOK_SECRET=

# ── Gemini Live (음성 응답 + 트랜스크립트 정제/분류) ── [필수]
GOOGLE_API_KEY=
# GEMINI_API_KEY=         # GOOGLE_API_KEY 대신 사용 가능

# ── Claude (call_classifier 통화 분류) ──
ANTHROPIC_API_KEY=

# ── Slack (통화 요약/녹음 전송) ── [선택]
SLACK_BOT_TOKEN=
# 발신번호 매핑이 없을 때 사용할 기본 채널/유저 ID
AICC_DEFAULT_SLACK_CHANNEL=

# ── 데이터 저장 루트 (DB, 녹음) ── [선택, 비우면 ~/.aicc]
FILESYSTEM_BASE_DIR=
# 녹음만 별도 경로로 두려면:
# AICC_RECORDING_PATH=/data/aicc_recordings

# ── AICC 발신번호 (070) ──
AICC_FROM_NUMBER=07012345678

# ── SMS 발송 (사후 안내) ── [선택, 하나 선택]
# SOLAPI
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
# 또는 NCP SENS
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_SMS_SERVICE_ID=
# 알림톡(선택)
NCP_KAKAO_CHANNEL=

# ── 웹 서버 ──
AICC_HOST=0.0.0.0
AICC_PORT=8000
# HTTPS (선택)
# AICC_SSL_CERT=./certs/cert.pem
# AICC_SSL_KEY=./certs/key.pem
